import java.util.*;

class Solution {
    public int[] sortedSquares(int[] nums) {
        int l = 0;
        int n = nums.length;
        int r = n - 1;
        int idx = n - 1;

        int[] ans = new int[n];

        while (l <= r) {
            if (Math.abs(nums[l]) > Math.abs(nums[r])) {
                ans[idx] = nums[l] * nums[l];
                l++;
            } else {
                ans[idx] = nums[r] * nums[r];
                r--;
            }
            idx--;
        }

        return ans;
    }
}