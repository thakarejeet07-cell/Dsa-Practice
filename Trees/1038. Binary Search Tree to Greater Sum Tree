class Solution {
    int sum = 0;
    public TreeNode bstToGst(TreeNode root) {
        tra(root);
        return root;
    }

    public void tra(TreeNode root){
        if(root == null){
            return;
        }
        tra(root.right);
        sum += root.val;
        root.val = sum;
        tra(root.left);

    }
}


